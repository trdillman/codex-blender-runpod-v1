BROKER_PUBLIC_BASE_URL=https://YOUR-POD-ID-8080.proxy.runpod.net
BROKER_BOOTSTRAP_SECRET=replace-me
BROKER_JWT_SECRET=replace-me-too
BROKER_DATA_DIR=/workspace/data
BROKER_ARTIFACT_DIR=/workspace/artifacts
BROKER_RUNTIME_HOST=127.0.0.1
BROKER_RUNTIME_PORT=9876
BROKER_VIEWER_BASE_URL=https://YOUR-POD-ID-3001.proxy.runpod.net

ADDON_ROOT=addons/your_addon
ADDON_MODULE=your_addon
SNAPSHOT_MODE=tarball

RUNPOD_API_KEY=replace-me
RUNPOD_IMAGE=ghcr.io/your-org/codex-blender-runpod:main
RUNPOD_GPU_CANDIDATES=NVIDIA GeForce RTX 4070 Ti,NVIDIA GeForce RTX 3090
RUNPOD_NAME=codex-blender-sandbox
RUNPOD_SECURE_CLOUD=true
RUNPOD_VOLUME_GB=80
RUNPOD_CONTAINER_DISK_GB=40
